{
    "name": "enteco/immo-connector",
    "description": "WordPress plugin for importing real estate data from Justimmo and OnOffice.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Enteco\\ImmoConnector\\": "includes/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
